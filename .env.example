# FastAPI settings
APP_HOST=192.168.1.63 # хост API
APP_PORT=8000 # порт API
APP_DEBUG=true # режим отладки
APP_TITLE=Springer Scrapper API # название API
APP_VERSION=0.1.0 # версия API

# OpenAI API
OPENAI_API_KEY=sk-... ключ OpenAI
OPENAI_MODEL=gpt-4o-mini # модель OpenAI
AI_TEMPERATURE=0.7 # температура генерации

# Database
# PostgreSQL only
# Пример для локального запуска:
# DATABASE_URL=postgres://springer:springer@localhost:5432/springer
# В Docker значение переопределяется в docker/docker-compose.yml
DATABASE_URL=postgres://springer:springer@localhost:5432/springer

# Auth / JWT
JWT_SECRET_KEY=change-me-to-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_PEPPER=change-me-pepper

# Admin panel
ADMIN_SECRET_KEY=changeme-replace-in-production # секретный ключ сессий (поменяй!)
