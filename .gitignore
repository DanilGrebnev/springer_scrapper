# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv

# Environment
.env

# SQLite databases (включая WAL/SHM)
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
*.db
*.db-wal
*.db-shm

# Results
results/

# Auto-generated database migrations (генерируются под текущую БД при старте)
migrations/models/*.py
!migrations/models/__init__.py
